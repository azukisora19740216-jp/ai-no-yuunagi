# ローカル開発専用の例です。本番の秘密情報を保存しないでください。
NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://ainoyuunagi:local_only_password@db:5432/ainoyuunagi?schema=public
AUTH_SECRET=local-development-only-change-me-32-characters
LOG_LEVEL=info

# 新しい制度ゲートは段階導入します。productionで有効化する前にDB設定を承認してください。
FEATURE_PILOT_ENROLLMENT=false
FEATURE_KYC_GATES=false
FEATURE_FORMAL_POINTS=false
FEATURE_POINT_EXPIRY=false
FEATURE_POINT_EXPIRY_NOTIFICATIONS=false
NATIONWIDE_PUBLIC_ENABLED=false

# 本番環境では false でなければ起動を拒否します。
ALLOW_MOCK_ADAPTERS=true
EMAIL_DRIVER=mock
KYC_DRIVER=mock
SHIPPING_DRIVER=mock
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=/app/.local-data/uploads

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

SMTP_HOST=mailpit
SMTP_PORT=1025
MAIL_FROM=no-reply@example.invalid
